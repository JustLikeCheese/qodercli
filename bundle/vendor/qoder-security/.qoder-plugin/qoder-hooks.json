{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${QODER_PLUGIN_ROOT}/bin/qodersec-launch.cmd\" ensure-deps --hook-event SessionStart",
            "timeout": 120
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${QODER_PLUGIN_ROOT}/bin/qodersec-launch.cmd\" review --platform=qoder"
          }
        ],
        "matcher": "Edit|Write|MultiEdit|NotebookEdit"
      }
    ],
    "Stop": []
  }
}
